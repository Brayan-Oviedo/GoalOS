# Output files (user-generated)
output/
output/*.json
output/*.html
*.html

# Allow package.json in root (needed for MCP)
!package.json

# Environment variables (NEVER commit real tokens)
.env
.env.local
.env.*
*.env
tokens.txt
secrets.txt

# Analysis files (local only)
TOKEN-ANALYSIS.md

# Push scripts with tokens (local only)
push-with-token.sh

# OS files
.DS_Store
Thumbs.db

# IDE
.vscode/
.idea/
*.swp
*.swo

# Node (if extended with npm packages)
node_modules/
package-lock.json
npm-debug.log*
yarn-debug.log*
yarn-error.log*
node_modules/
package-lock.json

# Logs
*.log
npm-debug.log*

# Temp files
tmp/
temp/
*.tmp
