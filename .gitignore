# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# GoalOS — Solo Archivos Esenciales
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Output generado por usuarios (excepto .gitkeep)
output/*
!output/.gitkeep
*.json
*.html

# Environment variables (NUNCA commitear tokens reales)
.env
.env.local
.env.*
*.env
tokens.txt
secrets.txt

# Archivos temporales/testing
CHANGELOG-*.md
SUCCESS.md
TEST_*.md
TOKEN-ANALYSIS.md
PUSH-TO-GITHUB.md
ARCHIVOS-ESENCIALES.md
push-to-github.sh
push-with-token.sh
test-*.sh
validate-all.sh
test-roadmap.json
*.backup
*.legacy
*.bak

# Sistema operativo
.DS_Store
Thumbs.db

# IDEs
.vscode/
.idea/
*.swp
*.swo

# Node (si se extiende con npm)
node_modules/
package-lock.json

# Logs
*.log
npm-debug.log*

# Temporales
tmp/
temp/
*.tmp
