# [7] HONEST ASSESSMENT
if jq -e '.honest_assessment // .veredicto_honesto' "$ROADMAP_FILE" > /dev/null 2>&1; then
  echo -e "${CYAN}   → Assessment${NC}"
  
  ASSESSMENT_KEY=$(jq -e '.honest_assessment' "$ROADMAP_FILE" > /dev/null 2>&1 && echo "honest_assessment" || echo "veredicto_honesto")
  
  ASSESSMENT_TEXT="🎯 VEREDICTO HONESTO\n\n"
  
  ACHIEVABLE=$(jq -r ".$ASSESSMENT_KEY.achievable // .$ASSESSMENT_KEY.es_posible // .$ASSESSMENT_KEY.is_possible // empty" "$ROADMAP_FILE" 2>/dev/null) || ACHIEVABLE=""
  [ -n "$ACHIEVABLE" ] && ASSESSMENT_TEXT="${ASSESSMENT_TEXT}¿Es posible? $ACHIEVABLE\n\n"
  
  EXPECTED=$(jq -r ".$ASSESSMENT_KEY.expected_result // .$ASSESSMENT_KEY.expected_result_3_months // .$ASSESSMENT_KEY.will_achieve // empty" "$ROADMAP_FILE" 2>/dev/null) || EXPECTED=""
  [ -n "$EXPECTED" ] && ASSESSMENT_TEXT="${ASSESSMENT_TEXT}✅ Resultado:\n$EXPECTED\n\n"
  
  KEY_FACTOR=$(jq -r ".$ASSESSMENT_KEY.key_factor // .$ASSESSMENT_KEY.factor_decisivo // .$ASSESSMENT_KEY.mayor_riesgo // empty" "$ROADMAP_FILE" 2>/dev/null) || KEY_FACTOR=""
  [ -n "$KEY_FACTOR" ] && ASSESSMENT_TEXT="${ASSESSMENT_TEXT}⚠️ Factor clave:\n$KEY_FACTOR"
  
  curl -s -X POST "https://api.miro.com/v2/boards/$BOARD_ID/shapes" \
    -H "Authorization: Bearer $MIRO_ACCESS_TOKEN" \
    -H "Content-Type: application/json" \
    -d "{
      \"data\": {
        \"content\": \"$ASSESSMENT_TEXT\",
        \"shape\": \"rectangle\"
      },
      \"style\": {
        \"fillColor\": \"$ASSESSMENT_BG\",
        \"textAlign\": \"left\",
        \"fontSize\": \"$FONT_SIZE_BODY\",
        \"color\": \"$HEADER_TEXT\",
        \"fontFamily\": \"$FONT_FAMILY\"
      },
      \"position\": {
        \"x\": $SIDEBAR_X,
        \"y\": $((TIP_Y + 680))
      },
      \"geometry\": {
        \"width\": 450,
        \"height\": 380
      }
    }" > /dev/null
  
  echo -e "${GREEN}   ✓ Assessment${NC}"
fi

