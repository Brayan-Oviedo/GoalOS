#!/bin/bash
# GoalOS — Enhanced Miro Board Creator with Visual Preferences
# Usage: goalos-miro [roadmap.json] [--interactive]

set -e

PLUGIN_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
ROADMAP_FILE="${1:-output/roadmap.json}"
INTERACTIVE_MODE=false

# Check for --interactive flag
for arg in "$@"; do
  if [ "$arg" = "--interactive" ] || [ "$arg" = "-i" ]; then
    INTERACTIVE_MODE=true
  fi
done

# Colors for terminal output
GREEN='\033[0;32m'
BLUE='\033[0;34m'
PURPLE='\033[0;35m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
RED='\033[0;31m'
NC='\033[0m'

echo ""
echo -e "${PURPLE}╔═══════════════════════════════════════════╗${NC}"
echo -e "${PURPLE}║   🎨 GoalOS → Miro Board (Enhanced)     ║${NC}"
echo -e "${PURPLE}╚═══════════════════════════════════════════╝${NC}"
echo ""

# Check Miro token
if [ -z "$MIRO_ACCESS_TOKEN" ]; then
  echo -e "${RED}❌ MIRO_ACCESS_TOKEN not found${NC}"
  echo ""
  echo -e "${YELLOW}Setup Instructions:${NC}"
  echo "1. Go to: https://miro.com/app/settings/user-profile/apps"
  echo "2. Create new app: 'GoalOS Board Generator'"
  echo "3. Get Access Token"
  echo "4. Export it:"
  echo ""
  echo -e "${CYAN}   export MIRO_ACCESS_TOKEN='your_token_here'${NC}"
  echo ""
  exit 1
fi

# Check roadmap exists
if [ ! -f "$ROADMAP_FILE" ]; then
  echo -e "${RED}❌ Roadmap file not found: $ROADMAP_FILE${NC}"
  echo ""
  echo "Run 'goalos \"your goal\"' first"
  echo ""
  exit 1
fi

echo -e "${BLUE}📂 Roadmap:${NC} $ROADMAP_FILE"
echo ""

# ═══════════════════════════════════════════════════════════════
# VISUAL PREFERENCES SYSTEM
# ═══════════════════════════════════════════════════════════════

VISUAL_CONFIG="output/visual-config.json"

# Check if roadmap has visual_preferences
HAS_VISUAL_PREFS=false
if jq -e '.visual_preferences' "$ROADMAP_FILE" > /dev/null 2>&1; then
  HAS_VISUAL_PREFS=true
fi

# Interactive mode or no preferences? Run wizard
if [ "$INTERACTIVE_MODE" = true ] || [ "$HAS_VISUAL_PREFS" = false ]; then
  if [ "$INTERACTIVE_MODE" = true ]; then
    echo -e "${CYAN}🎨 Modo interactivo activado${NC}"
    echo ""
  fi
  
  if [ -f "scripts/visual-preferences-wizard.sh" ]; then
    echo -e "${CYAN}Iniciando Visual Preferences Wizard...${NC}"
    echo ""
    bash scripts/visual-preferences-wizard.sh "$ROADMAP_FILE" "$VISUAL_CONFIG"
    echo ""
  else
    echo -e "${YELLOW}⚠️  Visual wizard not found, usando configuración por defecto${NC}"
    echo ""
  fi
fi

# Load visual preferences (from config, roadmap, or defaults)
if [ -f "$VISUAL_CONFIG" ]; then
  echo -e "${GREEN}✓ Cargando preferencias visuales de: $VISUAL_CONFIG${NC}"
  THEME=$(jq -r '.theme // "light"' "$VISUAL_CONFIG")
  COLOR_PRIMARY=$(jq -r '.color_palette.primary // "#667eea"' "$VISUAL_CONFIG")
  COLOR_SECONDARY=$(jq -r '.color_palette.secondary // "#764ba2"' "$VISUAL_CONFIG")
  COLOR_ACCENT=$(jq -r '.color_palette.accent // "#f093fb"' "$VISUAL_CONFIG")
  COLOR_BACKGROUND=$(jq -r '.color_palette.background // "#F8FAFC"' "$VISUAL_CONFIG")
  COLOR_SURFACE=$(jq -r '.color_palette.surface // "#FFFFFF"' "$VISUAL_CONFIG")
  COLOR_TEXT=$(jq -r '.color_palette.text // "#1a1a2e"' "$VISUAL_CONFIG")
  FONT_FAMILY=$(jq -r '.typography.family // "open_sans"' "$VISUAL_CONFIG")
  FONT_SIZE_TITLE=$(jq -r '.typography.sizes.title // "24"' "$VISUAL_CONFIG")
  FONT_SIZE_HEADER=$(jq -r '.typography.sizes.header // "20"' "$VISUAL_CONFIG")
  FONT_SIZE_BODY=$(jq -r '.typography.sizes.body // "14"' "$VISUAL_CONFIG")
  SHOW_TOOLS=$(jq -r '.advanced.show_tools // true' "$VISUAL_CONFIG")
  SHOW_TIPS=$(jq -r '.advanced.show_tips // true' "$VISUAL_CONFIG")
  SIDEBAR_POSITION=$(jq -r '.advanced.sidebar_position // "right"' "$VISUAL_CONFIG")
elif [ "$HAS_VISUAL_PREFS" = true ]; then
  echo -e "${GREEN}✓ Usando preferencias visuales del roadmap${NC}"
  THEME=$(jq -r '.visual_preferences.theme // "light"' "$ROADMAP_FILE")
  COLOR_PRIMARY=$(jq -r '.visual_preferences.color_palette.primary // "#667eea"' "$ROADMAP_FILE")
  COLOR_SECONDARY=$(jq -r '.visual_preferences.color_palette.secondary // "#764ba2"' "$ROADMAP_FILE")
  COLOR_ACCENT=$(jq -r '.visual_preferences.color_palette.accent // "#f093fb"' "$ROADMAP_FILE")
  COLOR_BACKGROUND=$(jq -r '.visual_preferences.color_palette.background // "#F8FAFC"' "$ROADMAP_FILE")
  COLOR_SURFACE=$(jq -r '.visual_preferences.color_palette.surface // "#FFFFFF"' "$ROADMAP_FILE")
  COLOR_TEXT=$(jq -r '.visual_preferences.color_palette.text // "#1a1a2e"' "$ROADMAP_FILE")
  FONT_FAMILY="open_sans"
  FONT_SIZE_TITLE="24"
  FONT_SIZE_HEADER="20"
  FONT_SIZE_BODY="14"
  SHOW_TOOLS=true
  SHOW_TIPS=true
  SIDEBAR_POSITION="right"
else
  echo -e "${YELLOW}⚠️  Usando colores por defecto${NC}"
  THEME="light"
  COLOR_PRIMARY="#667eea"
  COLOR_SECONDARY="#764ba2"
  COLOR_ACCENT="#f093fb"
  COLOR_BACKGROUND="#F8FAFC"
  COLOR_SURFACE="#FFFFFF"
  COLOR_TEXT="#1a1a2e"
  FONT_FAMILY="open_sans"
  FONT_SIZE_TITLE="24"
  FONT_SIZE_HEADER="20"
  FONT_SIZE_BODY="14"
  SHOW_TOOLS=true
  SHOW_TIPS=true
  SIDEBAR_POSITION="right"
fi

echo ""
echo -e "${CYAN}🎨 Configuración Visual:${NC}"
echo "   Theme: $THEME"
echo "   Primary: $COLOR_PRIMARY"
echo "   Secondary: $COLOR_SECONDARY"
echo "   Sidebar: $SIDEBAR_POSITION"
echo ""

# ═══════════════════════════════════════════════════════════════
# THEME-AWARE COLOR PALETTES
# ═══════════════════════════════════════════════════════════════

if [ "$THEME" = "dark" ]; then
  # Dark theme: vibrant colors for cards
  PHASE_FILLS=("#7C3AED" "#3B82F6" "#10B981" "#F59E0B" "#EF4444" "#EC4899")
  PHASE_BORDERS=("#A78BFA" "#60A5FA" "#34D399" "#FBBF24" "#F87171" "#F9A8D4")
  TOOLS_BG="#FCD34D"  # Yellow for tools (readable in dark)
  TIPS_BG="#34D399"   # Green for tips
  SCHEDULE_BG="#A78BFA"  # Purple for schedule
  ASSESSMENT_BG="#F87171"  # Red for assessment
  CARD_TEXT="#FFFFFF"
  HEADER_TEXT="#FFFFFF"
else
  # Light theme: soft pastel colors for cards
  PHASE_FILLS=("#fef3c7" "#dcfce7" "#dbeafe" "#fce7f3" "#ede9fe" "#ffedd5")
  PHASE_BORDERS=("#f59e0b" "#22c55e" "#3b82f6" "#ec4899" "#8b5cf6" "#f97316")
  TOOLS_BG="#fbbf24"
  TIPS_BG="#10b981"
  SCHEDULE_BG="#8b5cf6"
  ASSESSMENT_BG="#ef4444"
  CARD_TEXT="#1a1a2e"
  HEADER_TEXT="#ffffff"
fi

# ═══════════════════════════════════════════════════════════════
# BOARD CREATION / REUSE
# ═══════════════════════════════════════════════════════════════

BOARD_CACHE="output/.miro-board-cache.json"
X_OFFSET=0
CREATE_NEW_BOARD=true

if [ -f "$BOARD_CACHE" ]; then
  EXISTING_BOARD_ID=$(jq -r '.board_id' "$BOARD_CACHE" 2>/dev/null)
  EXISTING_BOARD_URL=$(jq -r '.board_url' "$BOARD_CACHE" 2>/dev/null)
  
  if [ -n "$EXISTING_BOARD_ID" ] && [ "$EXISTING_BOARD_ID" != "null" ]; then
    echo -e "${CYAN}📌 Board existente encontrado:${NC}"
    echo -e "   ${BLUE}$EXISTING_BOARD_URL${NC}"
    echo ""
    echo -e "${YELLOW}¿Qué quieres hacer?${NC}"
    echo "  1) Añadir al board existente (lado a lado)"
    echo "  2) Crear nuevo board limpio"
    echo ""
    read -p "Opción [1/2]: " CHOICE
    echo ""
    
    if [ "$CHOICE" = "1" ]; then
      CREATE_NEW_BOARD=false
      BOARD_ID="$EXISTING_BOARD_ID"
      BOARD_URL="$EXISTING_BOARD_URL"
      
      echo -e "${CYAN}Calculando posición...${NC}"
      
      ITEMS_RESPONSE=$(curl -s "https://api.miro.com/v2/boards/$BOARD_ID/items?limit=50" \
        -H "Authorization: Bearer $MIRO_ACCESS_TOKEN")
      
      MAX_X=$(echo "$ITEMS_RESPONSE" | jq -r '[.data[]? | (.position.x + (.geometry.width // 0))] | max // 0')
      
      if [ "$MAX_X" != "null" ] && [ "$MAX_X" -gt 0 ]; then
        X_OFFSET=$((MAX_X + 800))  # Larger margin for sidebar
        echo -e "${GREEN}   ✓ Posición: x=$X_OFFSET${NC}"
      else
        X_OFFSET=0
        echo -e "${GREEN}   ✓ Board vacío, iniciando en x=0${NC}"
      fi
      echo ""
    fi
  fi
fi

if [ "$CREATE_NEW_BOARD" = true ]; then
  echo -e "${CYAN}Creando board en Miro.com...${NC}"

  GOAL_TITLE=$(jq -r '.goal.title' "$ROADMAP_FILE")
  BOARD_NAME=$(echo "GoalOS: $GOAL_TITLE" | cut -c1-60)

  BOARD_RESPONSE=$(curl -s -X POST "https://api.miro.com/v2/boards" \
    -H "Authorization: Bearer $MIRO_ACCESS_TOKEN" \
    -H "Content-Type: application/json" \
    -d "{
      \"name\": \"$BOARD_NAME\",
      \"description\": \"Generated by GoalOS on $(date +'%Y-%m-%d')\"
    }")

  BOARD_ID=$(echo "$BOARD_RESPONSE" | jq -r '.id' 2>/dev/null)

  if [ -z "$BOARD_ID" ] || [ "$BOARD_ID" = "null" ]; then
    echo -e "${RED}   ✗ Failed to create board${NC}"
    echo "$BOARD_RESPONSE" | jq '.' 2>/dev/null || echo "$BOARD_RESPONSE"
    exit 1
  fi

  BOARD_URL=$(echo "$BOARD_RESPONSE" | jq -r '.viewLink')

  jq -n \
    --arg board_id "$BOARD_ID" \
    --arg board_url "$BOARD_URL" \
    --arg created_at "$(date -u +"%Y-%m-%dT%H:%M:%SZ")" \
    '{board_id: $board_id, board_url: $board_url, created_at: $created_at}' \
    > "$BOARD_CACHE"

  echo -e "${GREEN}   ✓ Board created: $BOARD_ID${NC}"
  echo ""
fi

# ═══════════════════════════════════════════════════════════════
# CONTENT RENDERING
# ═══════════════════════════════════════════════════════════════

echo -e "${CYAN}Agregando contenido al board...${NC}"
echo ""

# [1] HEADER
HEADER_TEXT="🎯 $(jq -r '.goal.title' "$ROADMAP_FILE")"
SUCCESS_TEXT="✅ Success: $(jq -r '.goal.success_criteria | join(", ")' "$ROADMAP_FILE")"

HEADER_JSON=$(jq -n \
  --arg content "$HEADER_TEXT\n$SUCCESS_TEXT" \
  --arg fillColor "$COLOR_PRIMARY" \
  --arg textColor "$HEADER_TEXT" \
  --argjson x $X_OFFSET \
  --arg fontSize "$FONT_SIZE_TITLE" \
  '{
    data: { content: $content, shape: "rectangle" },
    style: { fillColor: $fillColor, textAlign: "center", fontSize: $fontSize, color: "#ffffff", fontFamily: "open_sans" },
    position: { x: $x, y: 0 },
    geometry: { width: 1200, height: 140 }
  }')

curl -s -X POST "https://api.miro.com/v2/boards/$BOARD_ID/shapes" \
  -H "Authorization: Bearer $MIRO_ACCESS_TOKEN" \
  -H "Content-Type: application/json" \
  -d "$HEADER_JSON" > /dev/null

echo -e "${GREEN}   ✓ Header${NC}"

# [2] PHASES & TASKS — Indexed loops (fix: pipe|while subshell loses variable changes)
PHASE_COUNT=$(jq '.phases | length' "$ROADMAP_FILE")
X_POS=$X_OFFSET

for ((pi=0; pi<PHASE_COUNT; pi++)); do
  PHASE_NAME=$(jq -r ".phases[$pi].name" "$ROADMAP_FILE")
  PHASE_DURATION=$(jq -r ".phases[$pi].duration_weeks // \"?\"" "$ROADMAP_FILE")
  FILL_COLOR="${PHASE_FILLS[$((pi % 6))]}"
  BORDER_COLOR="${PHASE_BORDERS[$((pi % 6))]}"

  # Phase header
  PHASE_JSON=$(jq -n \
    --arg content "$PHASE_NAME\n$PHASE_DURATION weeks" \
    --arg fillColor "$COLOR_SECONDARY" \
    --arg fontSize "$FONT_SIZE_HEADER" \
    --argjson x $((X_POS + 200)) \
    '{
      data: { content: $content, shape: "rectangle" },
      style: { fillColor: $fillColor, textAlign: "center", fontSize: $fontSize, color: "#ffffff", fontFamily: "open_sans" },
      position: { x: $x, y: 200 },
      geometry: { width: 360, height: 90 }
    }')

  curl -s -X POST "https://api.miro.com/v2/boards/$BOARD_ID/shapes" \
    -H "Authorization: Bearer $MIRO_ACCESS_TOKEN" \
    -H "Content-Type: application/json" \
    -d "$PHASE_JSON" > /dev/null

  # Tasks — indexed loop (fix: pipe|while subshell loses TASK_Y changes)
  TASK_COUNT=$(jq ".phases[$pi].tasks | length" "$ROADMAP_FILE")
  TASK_Y=320

  for ((ti=0; ti<TASK_COUNT; ti++)); do
    TASK_TITLE=$(jq -r ".phases[$pi].tasks[$ti].title" "$ROADMAP_FILE")
    TASK_DESC=$(jq -r ".phases[$pi].tasks[$ti].description // \"\"" "$ROADMAP_FILE")
    TASK_HOURS=$(jq -r ".phases[$pi].tasks[$ti].estimated_hours // 0" "$ROADMAP_FILE")
    TASK_PRIORITY=$(jq -r ".phases[$pi].tasks[$ti].priority // \"medium\"" "$ROADMAP_FILE")
    TASK_SKILL=$(jq -r ".phases[$pi].tasks[$ti].assigned_skill // \"\"" "$ROADMAP_FILE")
    TASK_TOOLS=$(jq -r ".phases[$pi].tasks[$ti].tools_needed // [] | if type == \"array\" then join(\", \") else tostring end" "$ROADMAP_FILE" 2>/dev/null || echo "")
    TASK_DELIV=$(jq -r ".phases[$pi].tasks[$ti].deliverable // \"\"" "$ROADMAP_FILE")
    TASK_STEPS_HTML=$(jq -r "[.phases[$pi].tasks[$ti].steps[]? | \"<p>• <b>\(.order // \"\").</b> \(.action // \"\")\(if (.duration // \"\") != \"\" then \" <em>(\(.duration))</em>\" else \"\" end)</p>\"] | join(\"\")" "$ROADMAP_FILE" 2>/dev/null || echo "")

    PRIORITY_COLOR="#d1d5db"; PRIORITY_TEXT_COLOR="#6b7280"
    if [ "$TASK_PRIORITY" = "high" ]; then PRIORITY_COLOR="#fecaca"; PRIORITY_TEXT_COLOR="#b91c1c"
    elif [ "$TASK_PRIORITY" = "medium" ]; then PRIORITY_COLOR="#fef3c7"; PRIORITY_TEXT_COLOR="#b45309"; fi

    BASE_HEIGHT=240
    DESC_HEIGHT=0; [ -n "$TASK_DESC" ] && DESC_HEIGHT=80
    SKILL_HEIGHT=0; [ -n "$TASK_SKILL" ] && SKILL_HEIGHT=40
    TOOLS_HEIGHT=0; [ -n "$TASK_TOOLS" ] && TOOLS_HEIGHT=40
    STEP_COUNT=$(jq ".phases[$pi].tasks[$ti].steps | length // 0" "$ROADMAP_FILE" 2>/dev/null || echo 0)
    STEP_HEIGHT=$((STEP_COUNT * 48))
    CARD_HEIGHT=$((BASE_HEIGHT + DESC_HEIGHT + SKILL_HEIGHT + TOOLS_HEIGHT + STEP_HEIGHT))

    PRIORITY_UPPER=$(echo "$TASK_PRIORITY" | tr '[:lower:]' '[:upper:]')
    CARD_CONTENT="<p><strong>$TASK_TITLE</strong> <span style='background-color: $PRIORITY_COLOR; color: $PRIORITY_TEXT_COLOR; padding: 2px 8px; border-radius: 4px; font-size: 11px;'>⚡ $PRIORITY_UPPER</span></p>"
    CARD_CONTENT="$CARD_CONTENT<p>⏱️ ${TASK_HOURS}h &nbsp;|&nbsp; 📦 $TASK_DELIV</p>"
    CARD_CONTENT="$CARD_CONTENT<hr>"
    [ -n "$TASK_DESC" ] && CARD_CONTENT="$CARD_CONTENT<p><em>$TASK_DESC</em></p>"
    [ -n "$TASK_SKILL" ] && CARD_CONTENT="$CARD_CONTENT<p>🎯 <strong>Skill:</strong> $TASK_SKILL</p>"
    [ -n "$TASK_TOOLS" ] && CARD_CONTENT="$CARD_CONTENT<p>🛠️ <strong>Tools:</strong> $TASK_TOOLS</p>"
    [ -n "$TASK_STEPS_HTML" ] && CARD_CONTENT="$CARD_CONTENT<hr><p><strong>📋 Cómo hacerlo:</strong></p>$TASK_STEPS_HTML"

    TASK_JSON=$(jq -n \
      --arg content "$CARD_CONTENT" \
      --arg fillColor "$FILL_COLOR" \
      --arg borderColor "$BORDER_COLOR" \
      --arg textColor "$CARD_TEXT" \
      --arg fontSize "$FONT_SIZE_BODY" \
      --argjson x $((X_POS + 200)) \
      --argjson y $TASK_Y \
      --argjson h $CARD_HEIGHT \
      '{
        data: { content: $content, shape: "rectangle" },
        style: { fillColor: $fillColor, fillOpacity: "1.0", borderColor: $borderColor, borderWidth: "3", borderStyle: "normal", borderOpacity: "1.0", color: $textColor, fontSize: $fontSize, textAlign: "left", textAlignVertical: "top", fontFamily: "open_sans" },
        position: { x: $x, y: $y },
        geometry: { width: 350, height: $h }
      }')

    curl -s -X POST "https://api.miro.com/v2/boards/$BOARD_ID/shapes" \
      -H "Authorization: Bearer $MIRO_ACCESS_TOKEN" \
      -H "Content-Type: application/json" \
      -d "$TASK_JSON" > /dev/null

    TASK_Y=$((TASK_Y + CARD_HEIGHT + 25))
  done

  X_POS=$((X_POS + 420))
done

echo -e "${GREEN}   ✓ Phases & Tasks${NC}"

# ═══════════════════════════════════════════════════════════════
# SIDEBAR: ALL DATA — Tools, Tips, Schedule, Assessment + Extras
# ═══════════════════════════════════════════════════════════════

# X_POS is correct here (index loop above updated it properly)
SIDEBAR_X=$((X_POS + 100))
SIDEBAR_Y=200  # Cumulative Y — tracks current vertical position

# [3] TOOLS — indexed loop (fix: pipe|while subshell loses TOOL_Y)
if [ "$SHOW_TOOLS" = "true" ] && jq -e '.tools' "$ROADMAP_FILE" > /dev/null 2>&1; then
  echo -e "${CYAN}   → Tools${NC}"

  curl -s -X POST "https://api.miro.com/v2/boards/$BOARD_ID/shapes" \
    -H "Authorization: Bearer $MIRO_ACCESS_TOKEN" \
    -H "Content-Type: application/json" \
    -d "$(jq -n --arg fillColor "$TOOLS_BG" --arg fontSize "$FONT_SIZE_HEADER" --argjson x $SIDEBAR_X --argjson y $SIDEBAR_Y '{
      data: {content: "🛠️ HERRAMIENTAS RECOMENDADAS", shape: "rectangle"},
      style: {fillColor: $fillColor, textAlign: "center", fontSize: $fontSize, color: "#ffffff", fontFamily: "open_sans"},
      position: {x: $x, y: $y}, geometry: {width: 520, height: 85}
    }')" > /dev/null

  SIDEBAR_Y=$((SIDEBAR_Y + 100))
  TOOLS_TYPE=$(jq -r '.tools | type' "$ROADMAP_FILE" 2>/dev/null)

  if [ "$TOOLS_TYPE" = "object" ]; then
    mapfile -t TOOL_LINES < <(jq -r '.tools | to_entries[] | .key as $cat | .value | if type=="array" then .[] | "\($cat): \(.)" else "\($cat): \(.)" end' "$ROADMAP_FILE" 2>/dev/null)
    for tool_line in "${TOOL_LINES[@]}"; do
      curl -s -X POST "https://api.miro.com/v2/boards/$BOARD_ID/sticky_notes" \
        -H "Authorization: Bearer $MIRO_ACCESS_TOKEN" -H "Content-Type: application/json" \
        -d "$(jq -n --arg content "$tool_line" --argjson x $SIDEBAR_X --argjson y $SIDEBAR_Y '{
          data: {content: $content}, style: {fillColor: "yellow", textAlign: "left"},
          position: {x: $x, y: $y}, geometry: {width: 250, height: 160}
        }')" > /dev/null
      SIDEBAR_Y=$((SIDEBAR_Y + 180))
    done
  elif [ "$TOOLS_TYPE" = "array" ]; then
    TOOLS_COUNT=$(jq '.tools | length' "$ROADMAP_FILE" 2>/dev/null || echo 0)
    for ((ti=0; ti<TOOLS_COUNT; ti++)); do
      TOOL_CONTENT=$(jq -r ".tools[$ti] | if type == \"object\" then .name // .tool // tostring else . end" "$ROADMAP_FILE")
      if [ -n "$TOOL_CONTENT" ] && [ "$TOOL_CONTENT" != "null" ]; then
        curl -s -X POST "https://api.miro.com/v2/boards/$BOARD_ID/sticky_notes" \
          -H "Authorization: Bearer $MIRO_ACCESS_TOKEN" -H "Content-Type: application/json" \
          -d "$(jq -n --arg content "$TOOL_CONTENT" --argjson x $SIDEBAR_X --argjson y $SIDEBAR_Y '{
            data: {content: $content}, style: {fillColor: "yellow", textAlign: "left"},
            position: {x: $x, y: $y}, geometry: {width: 250, height: 160}
          }')" > /dev/null
        SIDEBAR_Y=$((SIDEBAR_Y + 180))
      fi
    done
  fi

  SIDEBAR_Y=$((SIDEBAR_Y + 60))
  echo -e "${GREEN}   ✓ Tools${NC}"
fi

# [4] TIPS — indexed loop (fix: pipe|while subshell loses TIP_Y)
if [ "$SHOW_TIPS" = "true" ] && jq -e '.tips' "$ROADMAP_FILE" > /dev/null 2>&1; then
  echo -e "${CYAN}   → Tips${NC}"
  TIPS_COUNT=$(jq '.tips | length' "$ROADMAP_FILE" 2>/dev/null || echo 0)

  curl -s -X POST "https://api.miro.com/v2/boards/$BOARD_ID/shapes" \
    -H "Authorization: Bearer $MIRO_ACCESS_TOKEN" -H "Content-Type: application/json" \
    -d "$(jq -n --arg fillColor "$TIPS_BG" --arg fontSize "$FONT_SIZE_HEADER" --argjson x $SIDEBAR_X --argjson y $SIDEBAR_Y '{
      data: {content: "💡 TIPS CLAVE", shape: "rectangle"},
      style: {fillColor: $fillColor, textAlign: "center", fontSize: $fontSize, color: "#ffffff", fontFamily: "open_sans"},
      position: {x: $x, y: $y}, geometry: {width: 520, height: 85}
    }')" > /dev/null

  SIDEBAR_Y=$((SIDEBAR_Y + 100))
  for ((ti=0; ti<TIPS_COUNT; ti++)); do
    TIP_TEXT=$(jq -r ".tips[$ti] | if type == \"object\" then .tip // .text // .content // tostring else . end" "$ROADMAP_FILE")
    if [ -n "$TIP_TEXT" ] && [ "$TIP_TEXT" != "null" ]; then
      curl -s -X POST "https://api.miro.com/v2/boards/$BOARD_ID/sticky_notes" \
        -H "Authorization: Bearer $MIRO_ACCESS_TOKEN" -H "Content-Type: application/json" \
        -d "$(jq -n --arg content "$TIP_TEXT" --argjson x $SIDEBAR_X --argjson y $SIDEBAR_Y '{
          data: {content: $content}, style: {fillColor: "green", textAlign: "left"},
          position: {x: $x, y: $y}, geometry: {width: 250, height: 140}
        }')" > /dev/null
      SIDEBAR_Y=$((SIDEBAR_Y + 160))
    fi
  done

  SIDEBAR_Y=$((SIDEBAR_Y + 60))
  echo -e "${GREEN}   ✓ Tips${NC}"
fi

# [5] SCHEDULE — all sub-formats (morning/afternoon/evening, minimum/ideal, weekday/weekend breakdown)
if jq -e '.daily_schedule' "$ROADMAP_FILE" > /dev/null 2>&1; then
  echo -e "${CYAN}   → Schedule${NC}"

  SCHEDULE_TEXT="📅 CALENDARIO DIARIO\n\n"
  MORNING=$(jq -r '.daily_schedule.morning // empty' "$ROADMAP_FILE" 2>/dev/null)
  AFTERNOON=$(jq -r '.daily_schedule.afternoon // empty' "$ROADMAP_FILE" 2>/dev/null)
  EVENING=$(jq -r '.daily_schedule.evening // empty' "$ROADMAP_FILE" 2>/dev/null)
  MINIMUM=$(jq -r '.daily_schedule.minimum // .daily_schedule.minimum_required // empty' "$ROADMAP_FILE" 2>/dev/null)
  IDEAL=$(jq -r '.daily_schedule.ideal // empty' "$ROADMAP_FILE" 2>/dev/null)
  [ -n "$MORNING" ]   && SCHEDULE_TEXT="${SCHEDULE_TEXT}🌅 Mañana: $MORNING\n\n"
  [ -n "$AFTERNOON" ] && SCHEDULE_TEXT="${SCHEDULE_TEXT}☀️ Tarde: $AFTERNOON\n\n"
  [ -n "$EVENING" ]   && SCHEDULE_TEXT="${SCHEDULE_TEXT}🌙 Noche: $EVENING\n\n"
  [ -n "$MINIMUM" ]   && SCHEDULE_TEXT="${SCHEDULE_TEXT}⚡ Mínimo: $MINIMUM\n\n"
  [ -n "$IDEAL" ]     && SCHEDULE_TEXT="${SCHEDULE_TEXT}🌟 Ideal: $IDEAL\n\n"

  if jq -e '.daily_schedule.weekday_breakdown' "$ROADMAP_FILE" > /dev/null 2>&1; then
    SCHEDULE_TEXT="${SCHEDULE_TEXT}📆 Entre semana:\n"
    mapfile -t WD_LINES < <(jq -r '.daily_schedule.weekday_breakdown | to_entries[] | "  • \(.key): \(.value)"' "$ROADMAP_FILE" 2>/dev/null)
    for line in "${WD_LINES[@]}"; do SCHEDULE_TEXT="${SCHEDULE_TEXT}$line\n"; done
    SCHEDULE_TEXT="${SCHEDULE_TEXT}\n"
  fi
  if jq -e '.daily_schedule.weekend_breakdown' "$ROADMAP_FILE" > /dev/null 2>&1; then
    SCHEDULE_TEXT="${SCHEDULE_TEXT}🏖️ Fin de semana:\n"
    mapfile -t WE_LINES < <(jq -r '.daily_schedule.weekend_breakdown | to_entries[] | "  • \(.key): \(.value)"' "$ROADMAP_FILE" 2>/dev/null)
    for line in "${WE_LINES[@]}"; do SCHEDULE_TEXT="${SCHEDULE_TEXT}$line\n"; done
  fi
  # Fallback: serialize all fields if nothing extracted
  if [ "$SCHEDULE_TEXT" = "📅 CALENDARIO DIARIO\n\n" ]; then
    SCHEDULE_TEXT="📅 CALENDARIO DIARIO\n\n$(jq -r '.daily_schedule | to_entries[] | "\(.key): \(.value)"' "$ROADMAP_FILE" 2>/dev/null)"
  fi

  curl -s -X POST "https://api.miro.com/v2/boards/$BOARD_ID/shapes" \
    -H "Authorization: Bearer $MIRO_ACCESS_TOKEN" -H "Content-Type: application/json" \
    -d "$(jq -n --arg text "$SCHEDULE_TEXT" --arg fillColor "$SCHEDULE_BG" --arg fontSize "$FONT_SIZE_BODY" --argjson x $SIDEBAR_X --argjson y $SIDEBAR_Y '{
      data: {content: $text, shape: "rectangle"},
      style: {fillColor: $fillColor, textAlign: "left", fontSize: $fontSize, color: "#ffffff", fontFamily: "open_sans"},
      position: {x: $x, y: $y}, geometry: {width: 450, height: 340}
    }')" > /dev/null

  SIDEBAR_Y=$((SIDEBAR_Y + 360))
  echo -e "${GREEN}   ✓ Schedule${NC}"
fi

# [6] HONEST ASSESSMENT — all fields (achievable, expected, will_NOT_achieve, key_factor, biggest_risk, mitigation)
if jq -e '.honest_assessment // .veredicto_honesto' "$ROADMAP_FILE" > /dev/null 2>&1; then
  echo -e "${CYAN}   → Assessment${NC}"

  ASSESSMENT_KEY=$(jq -e '.honest_assessment' "$ROADMAP_FILE" > /dev/null 2>&1 && echo "honest_assessment" || echo "veredicto_honesto")
  ACHIEVABLE=$(jq -r ".$ASSESSMENT_KEY.achievable // .$ASSESSMENT_KEY.es_posible // .$ASSESSMENT_KEY.is_possible // empty" "$ROADMAP_FILE" 2>/dev/null) || ACHIEVABLE=""
  EXPECTED=$(jq -r ".$ASSESSMENT_KEY.expected_result // .$ASSESSMENT_KEY.expected_result_3_months // .$ASSESSMENT_KEY.will_achieve // empty" "$ROADMAP_FILE" 2>/dev/null) || EXPECTED=""
  WONT=$(jq -r "[ .$ASSESSMENT_KEY.will_NOT_achieve[]? ] | join(\", \")" "$ROADMAP_FILE" 2>/dev/null) || WONT=""
  KEY_FACTOR=$(jq -r ".$ASSESSMENT_KEY.key_factor // .$ASSESSMENT_KEY.factor_decisivo // empty" "$ROADMAP_FILE" 2>/dev/null) || KEY_FACTOR=""
  BIGGEST_RISK=$(jq -r ".$ASSESSMENT_KEY.biggest_risk // .$ASSESSMENT_KEY.mayor_riesgo // empty" "$ROADMAP_FILE" 2>/dev/null) || BIGGEST_RISK=""
  MITIGATION=$(jq -r ".$ASSESSMENT_KEY.mitigation // empty" "$ROADMAP_FILE" 2>/dev/null) || MITIGATION=""

  ASSESSMENT_TEXT="🎯 VEREDICTO HONESTO\n\n"
  [ -n "$ACHIEVABLE" ]   && ASSESSMENT_TEXT="${ASSESSMENT_TEXT}¿Es posible? $ACHIEVABLE\n\n"
  [ -n "$EXPECTED" ]     && ASSESSMENT_TEXT="${ASSESSMENT_TEXT}✅ Resultado esperado:\n$EXPECTED\n\n"
  [ -n "$WONT" ]         && ASSESSMENT_TEXT="${ASSESSMENT_TEXT}❌ NO lograrás aún:\n$WONT\n\n"
  [ -n "$KEY_FACTOR" ]   && ASSESSMENT_TEXT="${ASSESSMENT_TEXT}⚠️ Factor clave:\n$KEY_FACTOR\n\n"
  [ -n "$BIGGEST_RISK" ] && ASSESSMENT_TEXT="${ASSESSMENT_TEXT}🚨 Mayor riesgo:\n$BIGGEST_RISK\n\n"
  [ -n "$MITIGATION" ]   && ASSESSMENT_TEXT="${ASSESSMENT_TEXT}🛡️ Mitigación:\n$MITIGATION"
  # Fallback: dump all fields if nothing extracted
  if [ "$ASSESSMENT_TEXT" = "🎯 VEREDICTO HONESTO\n\n" ]; then
    ASSESSMENT_TEXT="🎯 VEREDICTO HONESTO\n\n$(jq -r ".$ASSESSMENT_KEY | to_entries[] | \"\(.key): \(.value)\"" "$ROADMAP_FILE" 2>/dev/null)"
  fi

  curl -s -X POST "https://api.miro.com/v2/boards/$BOARD_ID/shapes" \
    -H "Authorization: Bearer $MIRO_ACCESS_TOKEN" -H "Content-Type: application/json" \
    -d "$(jq -n --arg text "$ASSESSMENT_TEXT" --arg fillColor "$ASSESSMENT_BG" --arg fontSize "$FONT_SIZE_BODY" --argjson x $SIDEBAR_X --argjson y $SIDEBAR_Y '{
      data: {content: $text, shape: "rectangle"},
      style: {fillColor: $fillColor, textAlign: "left", fontSize: $fontSize, color: "#ffffff", fontFamily: "open_sans"},
      position: {x: $x, y: $y}, geometry: {width: 450, height: 420}
    }')" > /dev/null

  SIDEBAR_Y=$((SIDEBAR_Y + 440))
  echo -e "${GREEN}   ✓ Assessment${NC}"
fi

# [7] DYNAMIC EXTRAS — render any other top-level field not already handled
KNOWN_KEYS='["goal","phases","dependencies","metadata","visual_preferences","tools","tips","daily_schedule","honest_assessment","veredicto_honesto","context"]'
mapfile -t EXTRA_KEYS < <(jq -r --argjson known "$KNOWN_KEYS" 'keys - $known | .[]' "$ROADMAP_FILE" 2>/dev/null)
for extra_key in "${EXTRA_KEYS[@]}"; do
  EXTRA_VAL=$(jq -r ".\"$extra_key\"" "$ROADMAP_FILE" 2>/dev/null)
  if [ -n "$EXTRA_VAL" ] && [ "$EXTRA_VAL" != "null" ]; then
    EXTRA_TYPE=$(jq -r ".\"$extra_key\" | type" "$ROADMAP_FILE" 2>/dev/null)
    EXTRA_TEXT="📌 $extra_key\n\n"
    if [ "$EXTRA_TYPE" = "array" ]; then
      EXTRA_TEXT="${EXTRA_TEXT}$(jq -r ".\"$extra_key\"[] | if type == \"string\" then \"• \" + . elif type == \"object\" then \"• \" + tostring else \"• \" + tostring end" "$ROADMAP_FILE" 2>/dev/null | head -8)"
    elif [ "$EXTRA_TYPE" = "object" ]; then
      EXTRA_TEXT="${EXTRA_TEXT}$(jq -r ".\"$extra_key\" | to_entries[] | .key + \": \" + (.value | tostring)" "$ROADMAP_FILE" 2>/dev/null | head -8)"
    else
      EXTRA_TEXT="${EXTRA_TEXT}$EXTRA_VAL"
    fi
    curl -s -X POST "https://api.miro.com/v2/boards/$BOARD_ID/shapes" \
      -H "Authorization: Bearer $MIRO_ACCESS_TOKEN" -H "Content-Type: application/json" \
      -d "$(jq -n --arg text "$EXTRA_TEXT" --argjson x $SIDEBAR_X --argjson y $SIDEBAR_Y '{
        data: {content: $text, shape: "rectangle"},
        style: {fillColor: "#e0f2fe", textAlign: "left", fontSize: "13", color: "#1a1a2e", fontFamily: "open_sans"},
        position: {x: $x, y: $y}, geometry: {width: 420, height: 200}
      }')" > /dev/null
    SIDEBAR_Y=$((SIDEBAR_Y + 220))
  fi
done

echo ""
echo -e "${GREEN}✅ Contenido agregado exitosamente${NC}"
echo ""

# ═══════════════════════════════════════════════════════════════
# SUMMARY
# ═══════════════════════════════════════════════════════════════

echo ""
echo -e "${PURPLE}╔═══════════════════════════════════════════╗${NC}"
echo -e "${PURPLE}║        ✅ Miro Board Created!            ║${NC}"
echo -e "${PURPLE}╚═══════════════════════════════════════════╝${NC}"
echo ""
echo -e "${GREEN}🔗 Board URL:${NC}"
echo "   $BOARD_URL"
echo ""
echo -e "${CYAN}📋 Board ID:${NC} $BOARD_ID"
echo -e "${CYAN}🎨 Theme:${NC} $THEME"
echo -e "${CYAN}🎯 Layout:${NC} Timeline with sidebar-$SIDEBAR_POSITION"
echo ""
echo -e "${YELLOW}💡 Tips:${NC}"
echo "   • Abre el board en Miro para verlo completo"
echo "   • Zoom out para ver todo el roadmap"
echo "   • Exporta como PDF desde Miro: … → Export"
echo ""

