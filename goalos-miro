    "primary_color": "$COLOR_PRIMARY",
    "secondary_color": "$COLOR_SECONDARY",
    "sidebar_position": "$SIDEBAR_POSITION"
  },
  "goal": $(jq '.goal' "$ROADMAP_FILE")
}
INFO
